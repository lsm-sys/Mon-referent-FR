{
  "name": "mon-referent-fr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "next dev -p 3001",
    "dev:clean": "node scripts/kill-port.js 3001 && npm run clean && npm run dev",
    "restart": "node scripts/kill-port.js 3001 && npm run clean && npm run dev",
    "build": "next build",
    "prestart": "node -e \"const fs=require('fs');if(!fs.existsSync('.next')){console.error('Сборка не найдена. Выполните: npm run build');process.exit(1)}\"",
    "start": "next start -p 3001",
    "lint": "eslint"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.21",
    "@tailwindcss/postcss": "^4.3.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^15.3.4",
    "postcss": "^8.5.15",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "typescript": "^5.8.3"
  }
}
